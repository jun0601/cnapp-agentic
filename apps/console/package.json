    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "json-schema-to-typescript": "^15.0.3",
    "msw": "^2.6.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
