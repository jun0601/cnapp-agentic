# 관제 앱 환경변수 (Vite — VITE_ 접두사만 클라이언트 노출)

# 목업 우선 스위치: true면 MSW가 API를 가로채 contracts/mock-*.json 서빙(백엔드 0).
# 실데이터 전환 시 false + VITE_API_BASE 지정(§15.5 스왑 포인트).
VITE_USE_MOCK=true

# console-backend(ALB) 베이스 URL. MOCK=true면 무시됨.
VITE_API_BASE=/api

# 개발용 초기 역할(viewer|approver). 목업 단계에서만 사용 — 헤더 역할 스위처로도 전환 가능.
# 실데이터에선 console-backend(Lambda)가 x-amzn-oidc-data JWT의 custom:groups로 판정.
VITE_MOCK_ROLE=viewer
